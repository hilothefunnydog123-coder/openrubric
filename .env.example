# ──────────────────────────────────────────────────────────────────────────
# OpenRubric environment
#
# Copy this file to `.env.local` and fill in the values you need.
# Every value is OPTIONAL: with no env set, OpenRubric runs in fully working
# DEMO MODE (in-memory demo data, simulated GitHub timelines and AI summaries).
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (auth + Postgres + realtime) ─────────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used by server-side imports/aggregation.
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub timeline review ────────────────────────────────────────────────
# A read-only Personal Access Token (no scopes needed for public repos).
# When absent, /api/github/scan returns simulated demo timelines.
GITHUB_TOKEN=

# ── AI project summaries (GitHub Models — free) ───────────────────────────
# Default provider is GitHub Models (https://github.com/marketplace/models), which
# is free with a GitHub PAT that has the `models` permission. The cheap, capable
# gpt-4o-mini model is used by default. When absent, /api/ai/summary returns
# deterministic demo summaries.
GITHUB_API_MODEL_KEY=
# Endpoint + model. Defaults below target GitHub Models; override for any other
# OpenAI-compatible API (OpenAI, Azure, Groq, Ollama…) — set OPENAI_API_KEY too.
OPENAI_BASE_URL=https://models.inference.ai.azure.com
AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=   # optional fallback for a non-GitHub OpenAI-compatible provider

# ── Email verification (Gmail SMTP via nodemailer) ────────────────────────
# Sends "verify your email" links. When absent, the app runs in DEMO MODE:
# no email is sent and the verify link is shown in the UI so the flow still works.
#
# Gmail setup (recommended):
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Put the account + the 16-char app password below (spaces are stripped).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# …or any generic SMTP server instead of Gmail:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Secret used to sign verification tokens. Defaults to the service-role key in dev;
# set an explicit random value in production.
EMAIL_TOKEN_SECRET=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
